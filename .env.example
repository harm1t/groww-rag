# ── Ingestion paths ──────────────────────────────────────────
INGEST_HASH_STORE_PATH=./data/hashes.json
INGEST_RAW_HTML_DIR=./data/raw
INGEST_SCRAPED_DIR=./data/scraped

# ── Scraping ─────────────────────────────────────────────────
INGEST_USER_AGENT=PPFAS-MF-FAQ-Bot/1.0 (Data Refresh)
INGEST_REQUEST_TIMEOUT=30
INGEST_RATE_LIMIT_SECS=2.0

# ── Embedding model (Phase 4.2) ──────────────────────────────
# Local BAAI/bge-small-en-v1.5 via sentence-transformers.
# No API key required — model is downloaded from HuggingFace Hub on first run (~130 MB).
# WARNING: changing this REQUIRES a full re-index (delete Chroma Cloud collection and re-run pipeline).
EMBED_MODEL=BAAI/bge-small-en-v1.5
EMBED_BATCH_SIZE=32

# ── Chroma Cloud (Phase 4.3) — trychroma.com ─────────────────
# Sign up at https://trychroma.com to get these credentials.
# NEVER commit these values to the repository.
# In CI: store in GitHub Secrets → available as ${{ secrets.CHROMA_API_KEY }} etc.
# In local dev: fill in below (this file is gitignored).
CHROMA_API_KEY=your_chroma_api_key_here
CHROMA_HOST=api.trychroma.com
CHROMA_TENANT=your_tenant_name_here
CHROMA_DATABASE=your_database_name_here
INGEST_CHROMA_COLLECTION=mf_faq_chunks

# ── LLM (Phase 6 — future) ───────────────────────────────────
# Groq chat API — completely independent of the embedding model.
# GROQ_API_KEY=your_groq_api_key_here
# GROQ_MODEL=llama-3.1-8b-instant
# GROQ_TEMPERATURE=0.1
# GROQ_MAX_TOKENS=300

# ── API (Phase 9 — future) ───────────────────────────────────
# PORT=8000
# API_HOST=0.0.0.0
# RUNTIME_API_DEBUG=0
# ADMIN_REINDEX_SECRET=changeme
